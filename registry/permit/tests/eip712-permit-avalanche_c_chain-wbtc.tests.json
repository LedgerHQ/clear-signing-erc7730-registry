            { "name": "spender", "type": "address" },
            { "name": "value", "type": "uint256" },
            { "name": "nonce", "type": "uint256" },
            { "name": "deadline", "type": "uint256" }
          ]
        },
        "primaryType": "Permit",
        "domain": { "name": "Bitcoin", "version": "1", "chainId": 43114, "verifyingContract": "0x152b9d0FdC40C096757F570A51E494bd4b943E50" },
        "message": {
