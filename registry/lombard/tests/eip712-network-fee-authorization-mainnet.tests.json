{
  "$schema": "../../../specs/erc7730-tests.schema.json",
  "tests": [
    {
      "description": "Lombard Network Fee Authorization",
      "data": {
        "types": {
          "EIP712Domain": [
            { "name": "name", "type": "string" },
            { "name": "version", "type": "string" },
            { "name": "chainId", "type": "uint256" },
            { "name": "verifyingContract", "type": "address" }
          ],
          "feeApproval": [{ "name": "chainId", "type": "uint256" }, { "name": "fee", "type": "uint256" }, { "name": "expiry", "type": "uint256" }]
        },
        "primaryType": "feeApproval",
        "domain": {
          "name": "Lombard Staked Bitcoin",
          "version": "1",
          "chainId": 1,
          "verifyingContract": "0x8236a87084f8B84306f72007F36F2618A5634494"
        },
        "message": { "chainId": 1, "fee": "300000000000000", "expiry": 1779321600 }
      },
      "expectedTexts": ["Network Fee", "Authorization", "Chain ID", "1 Network Fee 3000000 LBTC", "Expiry", "2026-05-21 12:00:00 AM UTC"]
    }
  ]
}
