            "visible": "always"
          },
          {
            "path": "amount",
            "label": "Amount Approved",
            "format": "tokenAmount",
            "params": { "token": "0xbbc7c3aff30f79e4dbcea65f368947809647f3a2" },
            "visible": "always"
          }
        ]
      }
    }
