{
  "$schema": "../../specs/erc7730-v1.schema.json",
  "context": {
    "$id": "CFHelpersForwarder",
    "eip712": {
      "deployments": [
        {
          "chainId": 1,
          "address": "0x824149CF6bab3DCDdf4103Bcf94cB8448c679FB5"
        },
        {
          "chainId": 8453,
          "address": "0x6C3d81Bd032D0796A12bc676948B876C4178CeD8"
        },
        {
          "chainId": 42161,
          "address": "0x6C3d81Bd032D0796A12bc676948B876C4178CeD8"
        }
      ],
      "domain": { "name": "Cofund Forwarder", "version": "1" },
      "schemas": [
        {
          "primaryType": "ForwardRequest",
          "types": {
            "EIP712Domain": [
              { "name": "name", "type": "string" },
              { "name": "version", "type": "string" },
              { "name": "chainId", "type": "uint256" },
              { "name": "verifyingContract", "type": "address" }
            ],
            "ForwardRequest": [
              { "name": "from", "type": "address" },
              { "name": "to", "type": "address" },
              { "name": "value", "type": "uint256" },
              { "name": "gas", "type": "uint256" },
              { "name": "nonce", "type": "string" },
              { "name": "data", "type": "bytes" }
            ]
          }
        }
      ]
    }
  },
  "metadata": {
    "owner": "Cofund",
    "info": {
      "legalName": "Cofund",
      "url": "https://getcofund.com"
    }
  },
  "display": {
    "formats": {
      "ForwardRequest": {
        "intent": "Cofund Authorization",
        "fields": [
          {
            "path": "from",
            "label": "Wallet",
            "format": "addressName",
            "params": {
              "types": ["wallet", "eoa"],
              "sources": ["local"]
            }
          },
          {
            "path": "to",
            "label": "Contract",
            "format": "addressName",
            "params": {
              "types": ["contract"],
              "sources": ["local"]
            }
          },
          {
            "path": "value",
            "label": "Value",
            "format": "amount"
          },
          {
            "path": "data",
            "label": "Call data",
            "format": "raw"
          }
        ],
        "required": ["to", "value", "data"],
        "excluded": ["gas", "nonce", "data.[]"]
      }
    }
  }
}
